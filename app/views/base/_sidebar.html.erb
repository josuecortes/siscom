<aside class="main-sidebar sidebar-dark-primary elevation-4">
  <!-- Brand Logo -->
  <a href="<%= home_index_url %>" class="brand-link">
    <%= image_tag('AdminLTELogo', class: "brand-image img-circle elevation-3", style: "opacity: .8") %>
    <span class="brand-text font-weight-light">Siscom SEED</span>
  </a>

