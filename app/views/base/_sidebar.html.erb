      <% nuinfo_active = ["nuinfo/requisicao_tis", "incidentes", "problema_tis", "tipo_problema_tis", "equipamentos"].include?(params[:controller]) %>
      <% administracao_active = ["usuarios", "unidades", "funcoes"].include?(params[:controller]) %>
