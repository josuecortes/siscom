            <li class="nav-item">
              <a href="<%= tarefas_path %>" class="nav-link <%= 'active' if (params[:controller] == 'tarefas' and params[:action] == 'index') %>">
                <i class="nav-icon fa fa-check"></i>
                <p>Tarefas</p>
              </a>
            </li>

            <% if current_user.has_role?(:req_serv_ti) %>
              <li class="nav-item">
                <a href="<%= movimentacao_equipamentos_path %>" class="nav-link <%= 'active' if (params[:controller] == 'movimentacao_equipamentos') %>">
                  <i class="nav-icon fas fa-exchange-alt"></i>
                  <p>Movimentações</p>
                </a>
              </li>
            <% end %>

            <% if current_user.has_role? :ges_acao %>
              <li class="nav-item">
                <a href="<%= acoes_path %>" class="nav-link">
                  <i class="nav-icon fa fa-copy"></i>
                  <p>Ações</p>
                </a>
              </li>
            <% end %>

            <% if current_user.has_role? :req_serv_midia %>
              <li class="nav-item">
                <a href="#" class="nav-link">
                  <i class="nav-icon fa fa-copy"></i>
                  <p>Requisições Mídia</p>
                </a>
              </li>
            <% end %>
          </ul>
        </li>

        <% if current_user.has_any_role? :tec_serv_tp, :master %>
          <li class="nav-item has-treeview <%= 'menu-open' if useget_active %>">
            <a href="#" class="nav-link <%= 'active' if useget_active %>">
              <i class="nav-icon fas fa-layer-group"></i>
              <p>
                Useget
                <i class="right fas fa-angle-left"></i>
              </p>
            </a>
            <ul class="nav nav-treeview">
              <li class="nav-item">
                <a href="<%= useget_requisicao_transportes_path %>" class="nav-link <%= 'active' if (params[:controller] == 'useget_requisicao_transportes' and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-desktop"></i>
                  <p>Requisições</p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= patio_index_url %>" class="nav-link <%= 'active' if (params[:controller] == 'patio' and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-home"></i>
                  <p>Patio</p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= veiculos_url %>" class="nav-link <%= 'active' if (params[:controller] == 'veiculos' and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-car"></i>
                  <p>Veiculos</p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= motoristas_url %>" class="nav-link <%= 'active' if (params[:controller] == 'motoristas' and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-users"></i>
                  <p>Motoristas</p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= acompanhamento_useget_requisicao_transportes_path %>" target='_blank' class="nav-link <%= 'active' if (params[:controller] == 'useget_requisicao_transportes' and params[:action] == 'acompanhamento') %>">
                  <i class="nav-icon far fa-bell"></i>
                  <p>
                    Acompanhamento
                  </p>
                </a>
              </li>
            </ul>
          </li>
        <% end %>

        <% if current_user.has_any_role? :ges_tp_es, :tec_tp_es, :master %>
