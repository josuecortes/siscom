                  <% if current_user.unidade.tipo_unidade.nome == "ESCOLA" %>
                    <p>Requisições Escola</p>
                  <% else %>
                    <p>Requisições TI</p>
                  <% end %>
                </a>
              </li>
            <% end %>

            <% if current_user.has_role? :req_serv_tp %>
              <li class="nav-item">
                <a href="<%= requisicao_transportes_path %>" class="nav-link <%= 'active' if (params[:controller] == 'requisicao_transportes' and params[:action] == 'index') %>">
