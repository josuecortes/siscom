                  <p>Requisições Transporte</p>
                </a>
              </li>
            <% end %>

            <% if current_user.has_role? :tec_serv_ti %>
              <li class="nav-item">
                <a href="<%= acoes_path %>" class="nav-link <%= 'active' if (params[:controller] == 'acoes' and params[:action] == 'index') %>">
