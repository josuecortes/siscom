            <p>
              Minha Área
              <i class="right fas fa-angle-left"></i>
            </p>
          </a>
          <ul class="nav nav-treeview">
            <% if current_user.has_role? :req_serv_ti %>
              <li class="nav-item">
                <a href="<%= mensagens_path %>" target="_blank" class="nav-link <%= 'active' if (params[:controller] == 'mensagens' and params[:action] == 'index') %>">
                  <i class="nav-icon fas fa-sms"></i>
                  <p>Mensagens Diretas <span id="mensagens-diretas"></span></p>
                </a>
              </li>
            <% end %>

            <% if current_user.has_role? :req_serv_ti %>
              <li class="nav-item">
                <a href="<%= requisicao_tis_path %>" class="nav-link <%= 'active' if (params[:controller] == 'requisicao_tis' and params[:action] == 'index') %>">
