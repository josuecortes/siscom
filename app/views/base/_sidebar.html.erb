              <li class="nav-item">
                <a href="<%= transporte_escolar_contratos_path %>" class="nav-link <%= 'active' if (params[:controller] == "transporte_escolar/contratos" and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-info"></i>
                  <p>Contratos</p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= transporte_escolar_escolas_path %>" class="nav-link <%= 'active' if (params[:controller] == "transporte_escolar/escolas" and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-info"></i>
                  <p>Escolas</p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= transporte_escolar_transportadores_path %>" class="nav-link <%= 'active' if (params[:controller] == "transporte_escolar/transportadores" and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-info"></i>
                  <p>Transportadores</p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= transporte_escolar_condutores_path %>" class="nav-link <%= 'active' if (params[:controller] == "transporte_escolar/condutores" and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-info"></i>
                  <p>Condutores</p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= transporte_escolar_veiculos_path %>" class="nav-link <%= 'active' if (params[:controller] == "transporte_escolar/veiculos" and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-info"></i>
                  <p>Veiculos</p>
                </a>
              </li>
            </ul>
          </li>
        <% end %>

        <% if current_user.has_any_role? :tec_serv_ti, :admin, :master %>
          <li class="nav-item has-treeview <%= 'menu-open' if nuinfo_active %>">
            <a href="#" class="nav-link <%= 'active' if nuinfo_active %>">
              <i class="nav-icon fas fa-network-wired"></i>
              <p>
                NuInfo
                <i class="right fas fa-angle-left"></i>
              </p>
            </a>
            <ul class="nav nav-treeview">
              <li class="nav-item">
                <a href="<%= nuinfo_requisicao_tis_path %>" class="nav-link <%= 'active' if (params[:controller] == 'nuinfo_requisicao_tis' and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-desktop"></i>
                  <p>
                    Requisições
                  </p>
                </a>
              </li>

               <li class="nav-item">
                <a href="<%= incidentes_path %>" class="nav-link <%= 'active' if (params[:controller] == 'incidentes' and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-info"></i>
                  <p>
                    Incidentes
                  </p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= problema_tis_path %>" class="nav-link <%= 'active' if (params[:controller] == 'problema_tis' and params[:action] == 'index') %>">
                  <i class="nav-icon far fa-bell"></i>
                  <p>
                    Problemas
                  </p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= tipo_problema_tis_path %>" class="nav-link <%= 'active' if (params[:controller] == 'tipo_problema_tis' and params[:action] == 'index') %>">
                  <i class="nav-icon far fa-edit"></i>
                  <p>
                    Tipos de Problemas
                  </p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= equipamentos_path %>" class="nav-link <%= 'active' if (params[:controller] == 'equipamentos' and params[:action] == 'index') %>">
                  <i class="nav-icon fas fa-desktop"></i>
                  <p>
                    Equipamentos
                  </p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= acompanhamento_nuinfo_requisicao_tis_path %>" target='_blank' class="nav-link <%= 'active' if (params[:controller] == 'nuinfo_requisicao_tis' and params[:action] == 'acompanhamento') %>">
                  <i class="nav-icon far fa-bell"></i>
                  <p>
                    Acompanhamento
                  </p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= em_atendimento_nuinfo_requisicao_tis_path %>" class="nav-link <%= 'active' if (params[:controller] == 'nuinfo_requisicao_tis' and params[:action] == 'em_atendimento') %>">
                  <i class="nav-icon far fa-star"></i>
                  <p>
                    Ultimos 60 dias
                  </p>
                </a>
              </li>

              <li class="nav-item">
                <a href="<%= estatisticas_nuinfo_requisicao_tis_path %>" class="nav-link <%= 'active' if (params[:controller] == 'nuinfo_requisicao_tis' and params[:action] == 'estatisticas') %>">
                  <i class="nav-icon far fa-map"></i>
                  <p>
                    Estatísticas
                  </p>
                </a>
              </li>
            </ul>
          </li>
        <% end %>


        <% if current_user.has_any_role? :tec_serv_ti, :admin, :master, :tec_serv_tp %>
          <li class="nav-item has-treeview <%= 'menu-open' if administracao_active %>">
            <a href="#" class="nav-link <%= 'active' if administracao_active %>">
              <i class="nav-icon fas fa-cogs"></i>
              <p>
                Administração
                <i class="right fas fa-angle-left"></i>
              </p>
            </a>
            <ul class="nav nav-treeview">
              <li class="nav-item">
                <a href="<%= usuarios_path %>" class="nav-link <%= 'active' if (params[:controller] == 'usuarios' and params[:action] == 'index') %>">
                  <i class="nav-icon fa fa-users"></i>
                  <p>Usuarios</p>
                </a>
              </li>

              <% if current_user.has_any_role? :tec_serv_ti, :admin, :master %>
                <li class="nav-item">
                  <a href="<%= unidades_url %>" class="nav-link <%= 'active' if (params[:controller] == 'unidades' and params[:action] == 'index') %>">
                    <i class="nav-icon fa fa-sitemap"></i>
                    <p>Unidades</p>
                  </a>
                </li>

                <li class="nav-item">
                  <a href="<%= funcoes_url %>" class="nav-link <%= 'active' if (params[:controller] == 'funcoes' and params[:action] == 'index') %>">
                    <i class="nav-icon fa fa-address-card"></i>
                    <p>Funções</p>
                  </a>
                </li>
              <% end %>
            </ul>
          </li>
        <% end %>


        
      </ul>
    </nav>
    <!-- /.sidebar-menu -->
  </div>
  <!-- /.sidebar -->
</aside>