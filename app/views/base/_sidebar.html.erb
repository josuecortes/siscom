              with font-awesome or any other icon font library -->

        <li class="nav-item">
          <a href="<%= home_index_url %>" class="nav-link <%= 'active' if (params[:controller] == 'home' and params[:action] == 'index') %>">
            <i class="nav-icon fas fa-tachometer-alt"></i>
            <p>
              Início
            </p>
          </a>
        </li>  
        
        <li class="nav-item has-treeview <%= 'menu-open' if minha_area_active %>">
          <a href="#" class="nav-link <%= 'active' if minha_area_active %>">
