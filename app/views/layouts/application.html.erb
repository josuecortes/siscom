        <style>
          .chat-float-button {
            position: fixed;
            right: 20px;
            bottom: 60px;
            z-index: 1050;
            border-radius: 50%;
            width: 56px;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #17a2b8;
            color: #fff;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
          }
          .chat-float-badge { position: absolute; top: -4px; right: -4px; }

          .chat-float-list-panel,
          .chat-float-window {
            position: fixed;
            z-index: 1050;
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 8px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.25);
            display: none;
            overflow: hidden;
            max-height: calc(100vh - 220px);
          }
          .chat-float-list-panel {
            right: 20px;
            bottom: 120px;
            width: 360px;
          }
          .chat-float-window {
            right: 400px;
            bottom: 120px;
            width: 460px;
            max-height: calc(100vh - 200px);
            z-index: 1051;
          }
          .chat-float-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 12px;
            border-bottom: 1px solid #ddd;
            background: #f8f9fa;
          }
          .chat-float-subtitle {
            margin-left: 8px;
            color: #9aa1a8;
            font-weight: 400;
            font-size: 13px;
          }
          .chat-float-body .time_date {
            font-size: 11px;
            margin-top: 6px;
          }
          .chat-float-body { padding: 8px; }
          .chat-float-body .inbox_msg { border: none; }
          .chat-float-body .inbox_people { width: 100%; border-right: none; padding: 6px; }
          .chat-float-body .mesgs { padding: 6px; }
          .chat-float-body .inbox_chat { max-height: calc(100vh - 360px); overflow-y: auto; padding-right: 4px; }
          .chat-float-body .msg_history { max-height: calc(100vh - 420px); overflow-y: auto; padding-right: 4px; }
          .chat-float-window .msg_history { max-height: calc(100vh - 400px); }
          .chat-float-body .type_msg { border-top: 1px solid #ddd; padding: 8px 0; position: sticky; bottom: 0; background: #fff; }
          .chat-float-body .input_msg_write { padding: 8px 0; }
          .chat-float-body .chat-float-footer { padding: 8px 0 4px; }
          .chat-float-body .chat_img { width: 14%; }
          .chat-float-body .chat_ib { width: 84%; }
          .chat-float-body .chat_ib h5 { font-size: 15px; margin: 0 0 6px 0; }
          .chat-float-body .chat_ib p { font-size: 13px; }
          .chat-float-body .profile-user-img { max-height: 36px; max-width: 36px; }
          .chat-float-body .outgoing_msg .sent_msg p { background: #007bff; color: #fff; }
          .chat-float-body .incoming_msg .received_msg p { background: #f1f1f1; color: #333; }
          .chat-float-body .sent_msg p,
          .chat-float-body .received_msg p { font-size: 14px; padding: 6px 10px; }
          .chat-float-body .outgoing_msg { text-align: right; }
          .chat-float-body .sent_msg { float: right; max-width: 80%; }
          .chat-float-body .received_msg { float: left; max-width: 80%; }
          .chat-float-body .incoming_msg_img { margin-right: 6px; }
          .chat-float-body .received_msg { padding-left: 0; }
          .chat-float-body .outgoing_msg:after,
          .chat-float-body .incoming_msg:after { content: ""; display: block; clear: both; }
          .chat-float-body .write_msg { width: 100%; }
          .chat-float-body .type_msg .row { margin: 0; }
          .chat-float-body .type_msg .col-12,
          .chat-float-body .type_msg .col-8,
          .chat-float-body .type_msg .col-4 { padding-left: 0; padding-right: 0; }

