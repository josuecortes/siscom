      <script>
        $(document).on('click', '#chat-float-button', function(e) {
          e.preventDefault();
          var $list = $('#chat-float-list-panel');
          var $win = $('#chat-float-window');
          $list.toggle();
          if ($list.is(':visible')) {
            $.get('<%= painel_mensagens_path %>', function(html) {
              var $tmp = $('<div>').html(html);
              var listHtml = $tmp.find('.inbox_people').prop('outerHTML');
              var winHtml = $tmp.find('.mesgs').prop('outerHTML');
              $('#chat-float-list-body').html(listHtml || '');
              $('#chat-float-window-body').html(winHtml || '');
              $win.hide();
            });
          } else {
            $win.hide();
          }
        });

        $(document).on('click', '#chat-float-list-close', function() {
          $('#chat-float-list-panel').hide();
          $('#chat-float-window').hide();
        });

        $(document).on('click', '#chat-float-window-close', function() {
          $('#chat-float-window').hide();
        });

        $(document).on('click', '.js-chat-float-item', function(e) {
          e.preventDefault();
          var reqId = $(this).data('requisicaoId');
          var userName = $(this).data('userName');
          var chamadoId = $(this).data('chamadoId');
          var maxLen = (window.innerWidth && window.innerWidth <= 480) ? 14 : 18;
          window.MensagensUI.currentRequisicaoId = reqId;
          $('.js-chat-float-item').removeClass('active');
          $(this).addClass('active');
          if (window.MensagensUI && window.MensagensUI.updateConversaBadge) {
            window.MensagensUI.updateConversaBadge(reqId, 0);
          }
          if (window.MensagensUI && window.MensagensUI.updateBadge) {
            window.MensagensUI.updateBadge('0');
          }
          if (userName) {
            var trimmed = userName.toString().trim();
            if (trimmed.length > maxLen) {
              trimmed = trimmed.substring(0, maxLen) + '...';
            }
            $('#chat-float-window-title').text(trimmed);
          } else {
            $('#chat-float-window-title').text('Conversa');
          }
          if (chamadoId) {
            $('#chat-float-window-subtitle').text('#' + chamadoId);
          } else {
            $('#chat-float-window-subtitle').text('');
          }
          $.get('<%= conversa_mensagens_path %>', { requisicao_ti: reqId }, function(html) {
            $('#chat-float-conversa').html(html);
            $('#chat-float-conversa').find('.chat-float-empty').remove();
            var $msg = $('#chat-float-conversa');
            if ($msg.length) {
              $msg.scrollTop($msg[0].scrollHeight);
              setTimeout(function() {
                $msg.scrollTop($msg[0].scrollHeight);
              }, 100);
            }
            $('#chat-float-form').attr('data-requisicao-id', reqId);
            $('#chat-float-window').show();
          });
        });

        $(document).on('submit', '#chat-float-form', function(e) {
          e.preventDefault();
          var $form = $(this);
          var reqId = $form.data('requisicaoId');
          if (!reqId) { return; }

          var $submit = $form.find('button[type="submit"]');
          var $file = $form.find('input[type="file"]');
          var file = $file[0] && $file[0].files && $file[0].files[0];
          if (file && file.size > (2 * 1024 * 1024)) {
            alert('O arquivo deve ser menor que 2MB. O arquivo foi removido.');
            $file.val('');
            return;
          }

          var formData = new FormData();
          formData.append('requisicao_ti', reqId);
          formData.append('mensagem', $form.find('input[name="mensagem"]').val());
          if (file) { formData.append('image', file); }

          $submit.prop('disabled', true);
          $.ajax({
            url: '<%= js_create_mensagens_path %>',
            data: formData,
            processData: false,
            contentType: false,
            method: 'POST',
            success: function() {
              $form.find('input[name="mensagem"]').val('');
              $file.val('');
            },
            complete: function() {
              $submit.prop('disabled', false);
            }
          });
        });

        $(document).on('click', '#chat-float-conversa, #chat-float-form input[type="text"]', function() {
          if (window.MensagensUI && window.MensagensUI.updateBadge) {
            window.MensagensUI.updateBadge('0');
          }
          if (window.MensagensUI && window.MensagensUI.updateConversaBadge && window.MensagensUI.currentRequisicaoId) {
            window.MensagensUI.updateConversaBadge(window.MensagensUI.currentRequisicaoId, 0);
          }
        });
      </script>

      <script>
        var tempo_de_refresh_application = 2000
        var pode_chatear = false
        var numero_de_mensagens = 0    
        
        
        $(document).ready(function(){
          

          $('.data').mask('00/00/0000')
          $('.cpf').mask('000.000.000-00')
          $('.cnpj').mask('00.000.000/0000-00')
          $('.celular').mask('(00) 00000-0000')
          $('.cep').mask('00000-000')
          $('.placa').mask('AAA AAAA')
          // $('.dinheiro').mask('#.##0,00', {reverse: true})
          $('.dinheiro').mask('###0.00', {reverse: true})
          // polling desativado: badge atualizado via ActionCable
          // loop()
          // requisitar_refresh()
        })

        window.MensagensUI = window.MensagensUI || {}
        window.MensagensUI.updateBadge = function(valor){
          if(valor != '0'){
            $('#mensagens-diretas').html('')
            $('#mensagens-diretas').addClass('badge badge-danger piscar')
            $('#mensagens-diretas').html(valor)

            $('#mensagens-diretas-header').removeClass('d-none')
            $('#mensagens-diretas-header').html(valor)
            $('#mensagens-float-badge').removeClass('d-none').html(valor)
            
            toastr.error('Você possui mensagens diretas não lidas!.')

          }else{
            $('#mensagens-diretas').html('')
            $('#mensagens-diretas').removeClass('badge badge-danger piscar')

            $('#mensagens-diretas-header').html('').addClass('d-none')
            $('#mensagens-float-badge').html('').addClass('d-none')
          }          
        }
        window.MensagensUI.updateConversaBadge = function(requisicaoId, count){
          var targets = $('[id="conversa-badge-' + requisicaoId + '"]');
          if (!targets.length) { return; }
          if (count && count > 0) {
            targets.html('<span class="badge badge-danger">' + count + '</span>');
          } else {
            targets.html('');
          }
