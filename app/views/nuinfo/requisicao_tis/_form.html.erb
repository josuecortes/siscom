<div class="modal-body">

  <%= form_for @requisicao_ti, url: salvar_nuinfo_requisicao_ti_path(@requisicao_ti), method: :put, remote: true do |f| %>
    <% if @requisicao_ti.errors.any? %>
      <div class="alert alert-danger alert-dismissible">
          <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
          <h5><i class="icon fas fa-ban"></i> Ops! Algo deu errado.</h5>
        </div>
    <% end %> 

    <%= f.hidden_field :status, value: 'Concluída' %>
    <%= f.hidden_field :data_hora_concluida, value: DateTime.now %>

    <div class="form-group">
      <%= f.label :problema_ti_id, "Requisição" %>
      <%= f.select :problema_ti_id, ProblemaTi.order(nome: :asc).all.map{ |p| [p.nome, p.id] }, { include_blank: true }, { class: "form-control js-searchable", required: true } %>
      <%= has_error(@requisicao_ti, :problema_ti_id) %>
    </div>

    <div class="form-group">
      <%= f.label :observacoes %>
      <%= f.text_area :observacoes, class: "form-control", readonly: true%>
      <%= has_error(@requisicao_ti, :observacoes) %>
    </div>

    <% if @requisicao_ti.problema_ti&.nome == 'PRODOC - CADASTRO DE INSTITUIÇÃO EXTERNA' %>
      <div class="row">
        <div class="form-group col-md-6">
          <%= f.label :prodoc_nome_da_instituicao_externa, 'Nome da instituição externa' %>
          <%= f.text_field :prodoc_nome_da_instituicao_externa, class: "form-control", readonly: true %>
        </div>
        <div class="form-group col-md-6">
          <%= f.label :prodoc_sigla_da_instituicao_externa, 'Sigla da instituição externa' %>
          <%= f.text_field :prodoc_sigla_da_instituicao_externa, class: "form-control", readonly: true %>
        </div>
      </div>

      <div class="row">
        <div class="form-group col-md-6">
          <%= f.label :prodoc_nome_unidade_organizacional_externa, 'Nome da unidade organizacional externa' %>
          <%= f.text_field :prodoc_nome_unidade_organizacional_externa, class: "form-control", readonly: true %>
        </div>
        <div class="form-group col-md-6">
          <%= f.label :prodoc_sigla_unidade_organizacional_externa, 'Sigla da unidade organizacional externa' %>
          <%= f.text_field :prodoc_sigla_unidade_organizacional_externa, class: "form-control", readonly: true %>
        </div>
      </div>

      <div class="row">
        <div class="form-group col-md-6">
          <%= f.label :prodoc_responsavel_instituicao_externa, 'Responsável da instituição externa' %>
          <%= f.text_field :prodoc_responsavel_instituicao_externa, class: "form-control", readonly: true %>
        </div>
        <div class="form-group col-md-6">
          <%= f.label :prodoc_cargo_do_responsavel_instituicao_externa, 'Cargo do responsável' %>
          <%= f.text_field :prodoc_cargo_do_responsavel_instituicao_externa, class: "form-control", readonly: true %>
        </div>
      </div>

      <div class="row">
        <div class="form-group col-md-6">
          <%= f.label :prodoc_pronome_responsavel_instituicao_externa, 'Pronome do responsável' %>
          <%= f.text_field :prodoc_pronome_responsavel_instituicao_externa, class: "form-control", readonly: true %>
        </div>
        <div class="form-group col-md-6">
          <%= f.label :prodoc_cep_instituicao_externa, 'CEP da instituição externa' %>
          <%= f.text_field :prodoc_cep_instituicao_externa, class: "form-control", readonly: true %>
        </div>
      </div>

      <div class="row">
        <div class="form-group col-md-6">
          <%= f.label :prodoc_cidade_instituicao_externa, 'Cidade da instituição externa' %>
          <%= f.text_field :prodoc_cidade_instituicao_externa, class: "form-control", readonly: true %>
        </div>
        <div class="form-group col-md-6">
          <%= f.label :prodoc_uf_instituicao_externa, 'UF da instituição externa' %>
          <%= f.text_field :prodoc_uf_instituicao_externa, class: "form-control", readonly: true %>
        </div>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :solucao %>
      <%= f.text_area :solucao, class: "form-control" %>
      <%= has_error(@requisicao_ti, :solucao) %>
    </div>

    <div class="modal-footer">
      <button type="submit" class="btn btn-success" data-disable-with="Salvar"><i class="icon fa fa-check"></i> Salvar</button>
      <button type="button" class="btn btn-danger" data-dismiss="modal"><i class="icon fas fa-ban"></i> Cancelar</button>
    </div>
  
  <% end %>
</div>

<script>
  $(document).ready(function() {
    $('.js-searchable').select2({
      placeholder: "Selecione",
      allowClear: true,
      theme: 'bootstrap',
      width: '100%'    
    });
  }); 
</script>