<% passed = false %>

<% if @tarefa.editable_by?(current_user) %>
  <% passed = true %>
<% end %>

<% if passed %>
  $('#form-modal-title').html("<i class='fa fa-edit'></i> Editar Tarefa");
  $('#form-modal-body').html('<%= j render("form") %>');
  $('#form-modal').modal('show');
<% else %>
  toastr.error('Sem permissão para editar essa tarefa.');
<% end %>