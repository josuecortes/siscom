<div class="modal-body">
  <%= form_for @usuario, url: "#{@url}", method: "#{@method}", remote: true do |f| %>
    <% if @usuario.errors.any? %>
      <div class="alert alert-danger alert-dismissible">
        <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
        <h5><i class="icon fas fa-ban"></i> Ops! Algo deu errado.</h5>
      </div>
    <% end %>

    <% if current_user.has_any_role? :tec_serv_ti, :admin, :master %> 
      <div class="form-group">
        <%= f.label :nome %>
        <%= f.text_field :nome, autofocus: true, class: "form-control", required: true %>
        <%= has_error(@usuario, :nome) %>
      </div>
      <div class="form-group">
        <%= f.label :email %>
        <%= f.text_field :email, class: "form-control", required: true %>
        <%= has_error(@usuario, :email) %>
      </div>
      <div class="form-group">
        <%= f.label :funcao_id, "Função" %>
        <%= f.hidden_field :funcao_id, id: 'user_funcao_id' %>
        <%= text_field_tag :funcao_nome, (@usuario.funcao&.nome), class: "form-control js-autocomplete-funcao", placeholder: 'Digite para buscar a função', required: true, autocomplete: 'off' %>
        <%= has_error(@usuario, :funcao_id) %>
      </div>
      <div class="form-group">
        <%= f.label :unidade_id %>
        <%= f.hidden_field :unidade_id, id: 'user_unidade_id' %>
        <%= text_field_tag :unidade_nome, (@usuario.unidade&.sigla_nome), class: "form-control js-autocomplete-unidade", placeholder: 'Digite para buscar a unidade', required: true, autocomplete: 'off' %>
        <%= has_error(@usuario, :unidade_id) %>
      </div>
      <div class="form-group">
        <%= f.label :role_ids, "Permissões" %>
        <%= f.collection_check_boxes(:role_ids, Role.autorizado(current_user).all, :id, :exibition_name) do |b| %>
          <div class="custom-control custom-switch custom-switch-off-danger custom-switch-on-success">
            <%= b.check_box class: "custom-control-input" %>
            <%= b.label class: "custom-control-label" do %>
              <%= b.label %>
            <% end %>
          </div>
        <% end %>
        <%= has_error(@usuario, :role) %>
      </div>
    <% else %>
      <div class="form-group">
        <%= label_tag "Nome" %>
        <%= text_field_tag '',(@usuario.nome if @usuario.nome), class: "form-control", readonly: true %>
      </div>
      <div class="form-group">
        <%= label_tag "E-mail" %>
        <%= text_field_tag '',(@usuario.email if @usuario.email), class: "form-control", readonly: true %>
      </div>
      <div class="form-group">
        <%= label_tag "Função" %>
        <%= text_field_tag '',(@usuario.funcao.nome if @usuario.funcao), class: "form-control", readonly: true %>
      </div>
      <div class="form-group">
        <%= label_tag "Unidade" %>
        <%= text_field_tag '',(@usuario.unidade.nome if @usuario.unidade), class: "form-control", readonly: true %>
      </div>
      <div class="form-group">
        <%= f.label :role_ids, "Permissões" %>
        <%= f.collection_check_boxes(:role_ids, Role.autorizado(current_user).all, :id, :exibition_name) do |b| %>
          <div class="custom-control custom-switch custom-switch-off-danger custom-switch-on-success">
            <%= b.check_box class: "custom-control-input", disabled: "disabled" %>
            <%= b.label class: "custom-control-label" do %>
              <%= b.label %>
            <% end %>
          </div>
        <% end %>
        <%= has_error(@usuario, :role) %>
      </div>
    <% end %>

    <div class="modal-footer">
      <button type="submit" class="btn btn-success" data-disable-with="Salvar"><i class="icon fa fa-check"></i> Salvar</button>
      <button type="button" class="btn btn-danger" data-dismiss="modal"><i class="icon fas fa-ban"></i> Cancelar</button>
    </div>
  <% end %>
</div>

<script>
  $(document).ready(function() {
    function bindAutocompleteWithHidden(inputSelector, hiddenSelector, url){
      $(inputSelector).autocomplete({
        minLength: 0,
        appendTo: $(inputSelector).closest('.modal-body'),
        position: { my: "left top", at: "left bottom", collision: "none" },
        source: function(request, response){
          $.getJSON(url, { term: request.term }, function(data){
            response($.map(data, function(item){ return { label: item.value, value: item.value, id: item.id }; }));
          });
        },
        select: function(event, ui){
          $(hiddenSelector).val(ui.item.id);
          $(inputSelector).val(ui.item.value).trigger('change');
          return false;
        },
        change: function(event, ui){
          if(!ui.item){ $(hiddenSelector).val(''); }
        }
      }).autocomplete("widget").addClass("ui-autocomplete-modal");

      // Mostrar todas as opções ao focar
      $(inputSelector).on('focus', function(){
        $(this).autocomplete("search", "");
      });

      // Limpar hidden quando o texto for apagado
      $(inputSelector).on('input', function(){
        if($(this).val() === '') { $(hiddenSelector).val(''); }
      });
    }

    // Inicializar autocompletes
    bindAutocompleteWithHidden('.js-autocomplete-funcao', '#user_funcao_id', '/autocompletes/funcoes');
    bindAutocompleteWithHidden('.js-autocomplete-unidade', '#user_unidade_id', '/autocompletes/unidades');

    // Garantir que o autocomplete apareça acima do modal
    $('<style>')
      .prop('type', 'text/css')
      .html(`
        .ui-autocomplete-modal {
          z-index: 9999 !important;
          max-height: 200px;
          overflow-y: auto;
          overflow-x: hidden;
        }
        .ui-autocomplete-modal .ui-menu-item {
          padding: 8px 12px;
          border-bottom: 1px solid #eee;
          cursor: pointer;
        }
        .ui-autocomplete-modal .ui-menu-item:last-child {
          border-bottom: none;
        }
      `)
      .appendTo('head');
  }); 
</script>
